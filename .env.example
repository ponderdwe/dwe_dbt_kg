# =============================================================
# DWE dbt Knowledge Graph — Environment Variables
# Copy to .env and fill in values.
# =============================================================

# ── Graph database ────────────────────────────────────────────
GRAPH_DB=falkordb
GRAPH_HOST=falkordb
GRAPH_PORT=6379
# Only needed if FalkorDB auth is enabled:
# GRAPH_USER=
# GRAPH_PASSWORD=

# ── LLM provider ─────────────────────────────────────────────
# Format: provider:model_id
# Examples:
#   bedrock:anthropic.claude-sonnet-4-20250514-v1:0
#   openai:gpt-4o
#   anthropic:claude-sonnet-4-5
LLM_MODEL_ID=bedrock:anthropic.claude-sonnet-4-20250514-v1:0

# API key — not needed when using Bedrock (uses IAM role on EC2)
# LLM_API_KEY=

# ── AWS (for Bedrock LLM + reranker) ─────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Bedrock reranker — Cohere Rerank v3.5 (used automatically when LLM_MODEL_ID starts with bedrock:)
# BEDROCK_RERANKER_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/cohere.rerank-v3-5:0

# ── Security ──────────────────────────────────────────────────
SECRET_KEY=change_me_to_random_string
FAST_API_ACCESS_SECRET_TOKEN=change_me_to_random_string
STREAMLIT_PASSWORD=change_me_to_random_string
